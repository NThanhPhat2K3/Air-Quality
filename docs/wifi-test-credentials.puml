@startuml wifi_test_credentials_flow
!theme plain
title Air Quality Node – WiFi Test-Before-Save Flow

skinparam activity {
  BackgroundColor #E1BEE7
  DiamondBackgroundColor #FFF9C4
}

|HTTP Handler|
start
:User submits POST /wifi\nwith SSID + Password;

|wifi_test_credentials()|
:Validate WiFi driver ready\n& EventGroup initialized;

if (Hidden network?) then (no)
  :Pre-scan WiFi APs\n(without disconnecting\ncurrent STA);
  
  if (Target SSID found\nin scan results?) then (no)
    :Return **WIFI_TEST_RESULT_NOT_FOUND**;
    |HTTP Handler|
    :Respond 200\n{"result":"not_found"};
    stop
  else (yes)
  endif
else (yes, hidden)
  :Skip pre-scan;
endif

:Save current WiFi mode\n& STA config (backup);

:Disconnect STA\n(keep AP alive if portal active);

:Set WiFi mode → APSTA;

:Apply test credentials config\n(authmode: WPA2_PSK);

:Set s_wifi_test_mode = true\nReset retry counter = 0;

:esp_wifi_connect();

:xEventGroupWaitBits(\n  CONNECTED_BIT | FAIL_BIT,\n  timeout: 15s,\n  max retries: 3);

if (CONNECTED_BIT set?) then (yes)
  :Reset s_wifi_test_mode = false;
  
  |HTTP Handler|
  :Save credentials to NVS\n(30s flash cooldown);
  :Respond 200\n{"result":"connected"};
  
  |wifi_test_credentials()|
  :Return **WIFI_TEST_RESULT_CONNECTED**;
  stop
  
else (no / timeout)
  :Reset s_wifi_test_mode = false;
  :Disconnect test connection;
  :Reset retry counter = 0;
  
  if (Portal was active?) then (yes)
    :Restore AP+STA portal mode;
    :Restore original STA config\n(if had previous credentials);
    :esp_wifi_connect()\nwith original config;
  else (no, runtime mode)
    :Set mode → STA;
    :Restore original STA config;
    :esp_wifi_connect()\nwith original config;
  endif
  
  if (FAIL_BIT reason?) then (wrong password)
    :Return **WIFI_TEST_RESULT_WRONG_PASSWORD**;
  else (timeout)
    :Return **WIFI_TEST_RESULT_TIMEOUT**;
  endif
  
  |HTTP Handler|
  :Respond 200\n{"result":"wrong_password"}\nor {"result":"timeout"};
  stop
endif

@enduml
